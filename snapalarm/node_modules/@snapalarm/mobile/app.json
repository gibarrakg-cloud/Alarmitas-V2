{
  "expo": {
    "name": "SnapAlarm",
    "slug": "snapalarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "snapalarm",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapalarm.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "SnapAlarm needs calendar access to import events as alarms.",
        "NSPhotoLibraryUsageDescription": "SnapAlarm needs photo access to pick alarm photos.",
        "NSCameraUsageDescription": "SnapAlarm needs camera access to take alarm photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.snapalarm.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        { "photosPermission": "SnapAlarm needs access to your photos to set alarm images." }
      ],
      [
        "expo-media-library",
        { "photosPermission": "SnapAlarm needs access to your photo library." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
