{
  "name": "@snapalarm/api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^8.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.15.0",
    "@snapalarm/ai-service": "*",
    "@snapalarm/image-processor": "*",
    "@snapalarm/retry-engine": "*",
    "@snapalarm/shared-types": "*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.3.2",
    "pino": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.15.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0"
  }
}
